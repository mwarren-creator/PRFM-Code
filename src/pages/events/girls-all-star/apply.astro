---
import Base from '../../../layouts/Base.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
---

<Base title="Apply — HS Girls Soccer All Star Game — PRFM Sports" description="Apply for the High School Girls Soccer All Star Game. Applications are reviewed by our selection committee.">
  <Nav />

  <div class="topbar">
    <a href="/events/girls-all-star" class="topbar-back">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      BACK TO EVENT
    </a>
  </div>

  <main>
    <section class="ap-hero">
      <div class="ap-container">
        <p class="ap-tag">APPLICATION</p>
        <h1 class="ap-heading">HIGH SCHOOL GIRLS<br/>ALL STAR GAME</h1>
        <p class="ap-sub">Tell us about you. Applications are reviewed by our selection committee. Selected players will be contacted via email.</p>
        <div class="ap-tip">
          <span class="ap-tip-label">TIP</span>
          Applications with every field completed are more likely to be considered.
        </div>
      </div>
    </section>

    <section class="ap-form-section">
      <div class="ap-container">
        <form class="ap-form" method="POST" name="girls-allstar-application" data-netlify="true" netlify-honeypot="bot-field" novalidate>
          <input type="hidden" name="form-name" value="girls-allstar-application" />
          <p style="display:none"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="ap-row">
            <div class="ap-field">
              <label class="ap-label" for="player-name">PLAYER NAME</label>
              <input class="ap-input" type="text" id="player-name" name="player_name" required autocomplete="name" />
            </div>
            <div class="ap-field">
              <label class="ap-label" for="player-email">PLAYER EMAIL</label>
              <input class="ap-input" type="email" id="player-email" name="player_email" required autocomplete="email" />
            </div>
          </div>

          <div class="ap-row">
            <div class="ap-field">
              <label class="ap-label" for="grade">GRADE (2026-2027)</label>
              <input class="ap-input" type="text" id="grade" name="grade" placeholder="e.g. Junior" />
            </div>
            <div class="ap-field">
              <label class="ap-label" for="position">POSITION</label>
              <input class="ap-input" type="text" id="position" name="position" placeholder="e.g. Center Mid" />
            </div>
          </div>

          <div class="ap-row">
            <div class="ap-field">
              <label class="ap-label" for="high-school">HIGH SCHOOL</label>
              <input class="ap-input" type="text" id="high-school" name="high_school" required />
            </div>
            <div class="ap-field">
              <label class="ap-label" for="club-team">CLUB TEAM <span class="ap-optional">(OPTIONAL)</span></label>
              <input class="ap-input" type="text" id="club-team" name="club_team" />
            </div>
          </div>

          <div class="ap-row">
            <div class="ap-field">
              <label class="ap-label" for="parent-name">PARENT NAME</label>
              <input class="ap-input" type="text" id="parent-name" name="parent_name" required />
            </div>
            <div class="ap-field">
              <label class="ap-label" for="parent-email">PARENT EMAIL</label>
              <input class="ap-input" type="email" id="parent-email" name="parent_email" required />
            </div>
          </div>

          <div class="ap-field ap-field--full">
            <label class="ap-label" for="video-url">HIGHLIGHT VIDEO URL <span class="ap-optional">(OPTIONAL)</span></label>
            <input class="ap-input" type="url" id="video-url" name="video_url" placeholder="https://youtube.com/..." />
          </div>

          <div class="ap-field ap-field--full">
            <label class="ap-label" for="instagram">INSTAGRAM HANDLE <span class="ap-optional">(OPTIONAL)</span></label>
            <input class="ap-input" type="text" id="instagram" name="instagram" placeholder="@yourhandle" />
          </div>

          <div class="ap-field ap-field--full">
            <label class="ap-label" for="state-your-case">STATE YOUR CASE</label>
            <textarea class="ap-textarea" id="state-your-case" name="state_your_case" rows="6"></textarea>
            <p class="ap-helper">Share your stats, achievements, accolades, and why you deserve a spot.</p>
          </div>

          <div class="ap-submit-row">
            <button type="submit" class="ap-submit">SUBMIT APPLICATION</button>
            <p class="ap-free">Free to apply. We'll email you about next steps.</p>
          </div>

        </form>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .topbar {
    position: sticky;
    top: 60px;
    z-index: 90;
    background: var(--cream);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    height: 52px;
    display: flex;
    align-items: center;
  }

  .topbar-back {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.2s;
  }

  .topbar-back:hover { color: var(--orange); }

  .ap-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .ap-hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .ap-tag {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--orange);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .ap-heading {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .ap-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted);
    max-width: 600px;
    margin-bottom: 1.75rem;
  }

  .ap-tip {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid var(--border);
    padding: 0.6rem 1rem;
    font-size: 0.88rem;
    color: var(--muted);
  }

  .ap-tip-label {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: var(--orange);
    text-transform: uppercase;
  }

  /* Form */
  .ap-form-section {
    padding: 4rem 0 6rem;
  }

  .ap-form {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .ap-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .ap-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ap-field--full {
    grid-column: 1 / -1;
  }

  .ap-label {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--ink);
    text-transform: uppercase;
  }

  .ap-optional {
    color: var(--muted);
    font-size: 0.68rem;
  }

  .ap-input {
    background: transparent;
    border: none;
    border-bottom: 1.5px solid var(--border);
    padding: 0.6rem 0;
    font-family: 'Archivo', sans-serif;
    font-size: 0.95rem;
    color: var(--ink);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }

  .ap-input::placeholder {
    color: var(--muted);
    opacity: 0.5;
  }

  .ap-input:focus {
    border-bottom-color: var(--orange);
  }

  .ap-textarea {
    background: transparent;
    border: 1.5px solid var(--border);
    padding: 0.75rem 1rem;
    font-family: 'Archivo', sans-serif;
    font-size: 0.95rem;
    color: var(--ink);
    outline: none;
    resize: vertical;
    transition: border-color 0.2s;
    width: 100%;
    line-height: 1.6;
  }

  .ap-textarea:focus {
    border-color: var(--orange);
  }

  .ap-helper {
    font-size: 0.82rem;
    color: var(--muted);
    margin-top: 0.25rem;
  }

  .ap-submit-row {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
  }

  .ap-submit {
    background: var(--orange);
    color: #0f1014;
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    padding: 0.9rem 2.5rem;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  .ap-submit:hover { background: #b8f020; }

  .ap-free {
    font-size: 0.88rem;
    color: var(--muted);
  }

  @media (max-width: 600px) {
    .ap-row {
      grid-template-columns: 1fr;
    }
  }
</style>
