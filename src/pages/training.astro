---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Training — PRFM Sports" description="Total Player Training Program. Improve technically with our thousand-touch ball mastery curriculum and increase your speed, explosiveness, power and core strength.">
  <Nav />

  <!-- Minimal top bar -->
  <div class="topbar">
    <a href="/" class="topbar-back">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      BACK TO HOME
    </a>
  </div>

  <main>

    <!-- Hero -->
    <section class="tr-hero">
      <div class="tr-container">
        <p class="tr-tag">TOTAL PLAYER TRAINING PROGRAM</p>
        <h1 class="tr-heading">JOIN TODAY TO IMPROVE YOUR SKILL & SAQ</h1>
        <div class="tr-desc">
          <p>Improve technically with our thousand-touch ball mastery curriculum and increase your speed, explosiveness, power and core strength with soccer-specific performance training.</p>
          <p>Our program has been tailored for over 25 years to develop youth soccer players at every level. We are excited to take you to the next phase of your soccer career.</p>
        </div>
        <button class="tr-register" data-open-modal>
          REGISTER &nbsp;&rarr;
        </button>
      </div>
    </section>

    <!-- What You'll Access -->
    <section class="tr-access">
      <div class="tr-container">
        <p class="tr-tag">WHAT YOU'LL ACCESS</p>
        <h2 class="tr-access-heading">A PROGRAM WITH EVERYTHING YOU NEED TO SUCCEED</h2>

        <div class="tr-cards">

          <div class="tr-card">
            <span class="tr-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="9" y1="15" x2="13" y2="15"/>
              </svg>
            </span>
            <h3 class="tr-card-title">PROGRAM DETAILS</h3>
            <p class="tr-card-body">Total Soccer Player — supplemental training for competitive players. Most players are willing to work hard, but they and their parents don't know the best way to do it. Our detailed program will help you develop into a Total Soccer Player.</p>
          </div>

          <div class="tr-card">
            <span class="tr-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </span>
            <h3 class="tr-card-title">SOCCER PERFORMANCE</h3>
            <p class="tr-card-body">Soccer specific workouts, plyometrics, jump rope, speed work, strength work and much more to become faster and more explosive on the field.</p>
          </div>

          <div class="tr-card">
            <span class="tr-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/>
              </svg>
            </span>
            <h3 class="tr-card-title">BALL MASTERY</h3>
            <p class="tr-card-body">We will challenge every player at all levels to master the ball. Increase juggling, improve first touch, understand the speed and weight of passes, and improve decision making along the way.</p>
          </div>

          <div class="tr-card">
            <span class="tr-card-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 10l4.553-2.069A1 1 0 0 1 21 8.87v6.26a1 1 0 0 1-1.447.9L15 14"/><rect x="3" y="6" width="12" height="12" rx="2"/>
              </svg>
            </span>
            <h3 class="tr-card-title">GAME EVALUATION</h3>
            <p class="tr-card-body">ADD-ON: Upload a full game video each month and have a professional coach and trainer break it down for you. Get personalized feedback on your game, your game IQ, or any other technique.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- Summer Schedule -->
    <section class="tr-schedule">
      <div class="tr-container">
        <p class="tr-tag">SUMMER SCHEDULE</p>
        <h2 class="tr-schedule-heading">GROUP TRAINING</h2>
        <p class="tr-schedule-sub">4 Sessions per Month &nbsp;—&nbsp; SAQ Training with Ball Mastery &nbsp;—&nbsp; $75</p>
        <p class="tr-schedule-day">Choose your day — Mon or Wed</p>
        <p class="tr-schedule-location">Peak Athlete Facility &nbsp;·&nbsp; 86 E 800 N, Orem</p>

        <div class="tr-sessions">

          <div class="tr-session">
            <p class="tr-session-label">SESSION 01</p>
            <h3 class="tr-session-dates">JUNE 15 – JULY 8</h3>
            <p class="tr-session-desc">Improve your technical ability, speed, agility and quickness this summer to compete at a higher level in the upcoming season.</p>
            <p class="tr-session-times-label">AVAILABLE TIMES</p>
            <p class="tr-session-times">6:00 – 7:00 PM or 7:00 – 8:00 PM</p>
            <button class="tr-session-btn" data-open-modal data-session="01">REGISTER &nbsp;&rarr;</button>
          </div>

          <div class="tr-session">
            <p class="tr-session-label">SESSION 02</p>
            <h3 class="tr-session-dates">JULY 13 – AUG 5</h3>
            <p class="tr-session-desc">Develop more power and explosiveness in soccer specific movements while improving your technical skills with the ball.</p>
            <p class="tr-session-times-label">AVAILABLE TIMES</p>
            <p class="tr-session-times">6:00 – 7:00 PM or 7:00 – 8:00 PM</p>
            <button class="tr-session-btn" data-open-modal data-session="02">REGISTER &nbsp;&rarr;</button>
          </div>

          <div class="tr-session">
            <p class="tr-session-label">SESSION 03</p>
            <h3 class="tr-session-dates">AUGUST 10 – SEPT 2</h3>
            <p class="tr-session-desc">In-season focus on first touch, head-up decision making, speed of play and quick close touches for in-game scenarios.</p>
            <p class="tr-session-times-label">AVAILABLE TIMES</p>
            <p class="tr-session-times">6:30 – 7:30 PM or 7:30 – 8:30 PM</p>
            <button class="tr-session-btn" data-open-modal data-session="03">REGISTER &nbsp;&rarr;</button>
          </div>

        </div>
      </div>
    </section>

    <!-- Why Choose -->
    <section class="tr-why">
      <div class="tr-container">
        <h2 class="tr-why-heading">WHY CHOOSE THIS PROGRAM?</h2>
        <div class="tr-why-inner">
          <p class="tr-why-label">OVER 25 YEARS</p>
          <div class="tr-why-body">
            <p>With over 5,000 players trained, Morgan understands the development and soccer industry better than 99% of US soccer experts. Our comprehensive platform offers specialized training in every area of soccer development. Whether you're honing your technique or refining your physicality, our curated programs ensure you learn from the best.</p>
            <p>Elevate your game and excel in soccer with additional training, mental performance work and video analysis — in-season and off-season.</p>
            <button class="tr-register" style="margin-top: 1.5rem;" data-open-modal>REGISTER &nbsp;&rarr;</button>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />

  <!-- Netlify form detection (hidden static form) -->
  <form name="training-registration" data-netlify="true" netlify-honeypot="bot-field" hidden>
    <input type="hidden" name="form-name" value="training-registration" />
    <input name="session" />
    <input name="day" />
    <input name="time" />
    <input name="parent_name" />
    <input name="email" />
    <input name="phone" />
    <input name="player_name" />
  </form>

  <!-- Registration Modal -->
  <div id="registerModal" class="rm-overlay" role="dialog" aria-modal="true" aria-labelledby="rmTitle">
    <div class="rm-box">
      <button class="rm-close" id="rmClose" aria-label="Close">&times;</button>
      <p class="rm-title" id="rmTitle">REGISTER FOR GROUP TRAINING</p>
      <p class="rm-subtitle">Confirm your session, day and time. $75 per month &mdash; 4 sessions.</p>

      <form id="rmForm" novalidate>
        <input type="hidden" name="form-name" value="training-registration" />
        <input type="hidden" name="bot-field" />

        <div class="rm-row rm-row-3">
          <div class="rm-field">
            <label for="rmSession">SESSION *</label>
            <select id="rmSession" name="session" required>
              <option value="">Select session</option>
              <option value="Session 01 — June 15–July 8">Session 01 — June 15–July 8</option>
              <option value="Session 02 — July 13–Aug 5">Session 02 — July 13–Aug 5</option>
              <option value="Session 03 — Aug 10–Sept 2">Session 03 — Aug 10–Sept 2</option>
            </select>
          </div>

          <div class="rm-field">
            <label for="rmDay">DAY *</label>
            <select id="rmDay" name="day" required>
              <option value="Mon or Wed">Mon or Wed</option>
              <option value="Monday">Monday</option>
              <option value="Wednesday">Wednesday</option>
            </select>
          </div>

          <div class="rm-field">
            <label for="rmTime">TIME *</label>
            <select id="rmTime" name="time" required disabled>
              <option value="">Select session first</option>
            </select>
          </div>
        </div>

        <div class="rm-row rm-row-2">
          <div class="rm-field">
            <label for="rmParent">PARENT / GUARDIAN NAME *</label>
            <input type="text" id="rmParent" name="parent_name" placeholder="Full name" required />
          </div>

          <div class="rm-field">
            <label for="rmEmail">EMAIL *</label>
            <input type="email" id="rmEmail" name="email" placeholder="email@example.com" required />
          </div>
        </div>

        <div class="rm-row rm-row-2">
          <div class="rm-field">
            <label for="rmPhone">PHONE NUMBER *</label>
            <input type="text" id="rmPhone" name="phone" placeholder="(555) 123-4567" required />
          </div>

          <div class="rm-field">
            <label for="rmPlayer">PLAYER NAME *</label>
            <input type="text" id="rmPlayer" name="player_name" placeholder="Full name" required />
          </div>
        </div>

        <button type="submit" class="rm-submit">CONTINUE TO PAYMENT</button>
      </form>
    </div>
  </div>

  <style>
    .rm-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      z-index: 200;
      align-items: center;
      justify-content: center;
      padding: 1rem;
    }
    .rm-overlay.is-open {
      display: flex;
    }
    .rm-box {
      position: relative;
      background: #fff;
      max-width: 560px;
      width: 100%;
      padding: 2rem;
      max-height: 90vh;
      overflow-y: auto;
    }
    .rm-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
      background: none;
      border: none;
      font-size: 1.4rem;
      line-height: 1;
      cursor: pointer;
      color: #0f1014;
      padding: 0.2rem 0.4rem;
    }
    .rm-title {
      font-family: 'Archivo Black', sans-serif;
      font-size: 1.15rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: #0f1014;
      margin-bottom: 0.4rem;
    }
    .rm-subtitle {
      font-size: 0.88rem;
      color: #6b6b6b;
      margin-bottom: 1.75rem;
    }
    .rm-row {
      display: grid;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .rm-row-3 { grid-template-columns: repeat(3, 1fr); }
    .rm-row-2 { grid-template-columns: repeat(2, 1fr); }
    .rm-field {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .rm-field label {
      font-family: 'Archivo Black', sans-serif;
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #0f1014;
    }
    .rm-field input,
    .rm-field select {
      width: 100%;
      border: 1px solid #d9d0c5;
      padding: 0.65rem 0.75rem;
      font-family: 'Archivo', sans-serif;
      font-size: 0.9rem;
      color: #0f1014;
      background: #fff;
      border-radius: 0;
      -webkit-appearance: none;
      appearance: none;
      box-sizing: border-box;
    }
    .rm-field input:focus,
    .rm-field select:focus {
      outline: 2px solid #cfff3d;
      outline-offset: -2px;
    }
    .rm-field input.rm-error,
    .rm-field select.rm-error {
      border-color: #e03434;
    }
    .rm-field select:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .rm-submit {
      display: block;
      width: 100%;
      background: #cfff3d;
      color: #0f1014;
      font-family: 'Archivo Black', sans-serif;
      font-size: 0.85rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 1rem;
      border: none;
      cursor: pointer;
      margin-top: 1.25rem;
      transition: background 0.2s;
    }
    .rm-submit:hover { background: #b8f020; }
    @media (max-width: 520px) {
      .rm-row-3 { grid-template-columns: 1fr; }
      .rm-row-2 { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    const STRIPE_URL = 'https://buy.stripe.com/5kQ00jfdo4rnd1t9iU0x207';

    const SESSION_TIMES = {
      '01': ['6:00–7:00 PM', '7:00–8:00 PM'],
      '02': ['6:00–7:00 PM', '7:00–8:00 PM'],
      '03': ['6:30–7:30 PM', '7:30–8:30 PM'],
    };

    const SESSION_VALUES = {
      '01': 'Session 01 — June 15–July 8',
      '02': 'Session 02 — July 13–Aug 5',
      '03': 'Session 03 — Aug 10–Sept 2',
    };

    const overlay = document.getElementById('registerModal');
    const closeBtn = document.getElementById('rmClose');
    const sessionSelect = document.getElementById('rmSession') as HTMLSelectElement;
    const timeSelect = document.getElementById('rmTime') as HTMLSelectElement;
    const form = document.getElementById('rmForm') as HTMLFormElement;

    function updateTimes(sessionKey: string) {
      timeSelect.innerHTML = '';
      if (!sessionKey) {
        const opt = document.createElement('option');
        opt.value = '';
        opt.textContent = 'Select session first';
        timeSelect.appendChild(opt);
        timeSelect.disabled = true;
        return;
      }
      const times = SESSION_TIMES[sessionKey as keyof typeof SESSION_TIMES];
      if (!times) return;
      times.forEach((t) => {
        const opt = document.createElement('option');
        opt.value = t;
        opt.textContent = t;
        timeSelect.appendChild(opt);
      });
      timeSelect.disabled = false;
    }

    function openModal(sessionKey?: string) {
      if (sessionKey) {
        sessionSelect.value = SESSION_VALUES[sessionKey as keyof typeof SESSION_VALUES] || '';
        updateTimes(sessionKey);
      } else {
        sessionSelect.value = '';
        updateTimes('');
      }
      overlay!.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      overlay!.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    // Open modal on button click
    document.querySelectorAll('[data-open-modal]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const sessionKey = (btn as HTMLElement).dataset.session;
        openModal(sessionKey);
      });
    });

    // Close on X button
    closeBtn!.addEventListener('click', closeModal);

    // Close on overlay background click
    overlay!.addEventListener('click', (e) => {
      if (e.target === overlay) closeModal();
    });

    // Session change updates time options
    sessionSelect.addEventListener('change', () => {
      const val = sessionSelect.value;
      const key = Object.keys(SESSION_VALUES).find(
        (k) => SESSION_VALUES[k as keyof typeof SESSION_VALUES] === val
      );
      updateTimes(key || '');
    });

    // Form submit
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous errors
      form.querySelectorAll('.rm-error').forEach((el) => el.classList.remove('rm-error'));

      // Validate
      let valid = true;
      const required = form.querySelectorAll('[required]');
      required.forEach((field) => {
        const el = field as HTMLInputElement | HTMLSelectElement;
        if (!el.value.trim()) {
          el.classList.add('rm-error');
          valid = false;
        }
      });
      if (!valid) return;

      const submitBtn = form.querySelector('.rm-submit') as HTMLButtonElement;
      submitBtn.textContent = 'SUBMITTING…';
      submitBtn.disabled = true;

      try {
        const formData = new FormData();
        formData.append('form-name', 'training-registration');
        formData.append('session', (document.getElementById('rmSession') as HTMLSelectElement).value);
        formData.append('day', (document.getElementById('rmDay') as HTMLSelectElement).value);
        formData.append('time', (document.getElementById('rmTime') as HTMLSelectElement).value);
        formData.append('parent_name', (document.getElementById('rmParent') as HTMLInputElement).value);
        formData.append('email', (document.getElementById('rmEmail') as HTMLInputElement).value);
        formData.append('phone', (document.getElementById('rmPhone') as HTMLInputElement).value);
        formData.append('player_name', (document.getElementById('rmPlayer') as HTMLInputElement).value);

        await fetch('/', { method: 'POST', body: formData });
      } catch (_) {
        // Proceed to Stripe even if Netlify submission fails
      }

      window.location.href = STRIPE_URL;
    });
  </script>
</Base>

<style>
  /* Top bar */
  .topbar {
    position: sticky;
    top: 60px;
    z-index: 90;
    background: var(--cream);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    height: 52px;
    display: flex;
    align-items: center;
  }

  .topbar-back {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.2s;
  }

  .topbar-back:hover { color: var(--orange); }

  /* Container */
  .tr-container {
    
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Tag */
  .tr-tag {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  /* Hero */
  .tr-hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .tr-heading {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 6vw, 6.5rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
    max-width: 900px;
    margin-bottom: 2rem;
  }

  .tr-desc {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 640px;
    margin-bottom: 2.5rem;
  }

  .tr-desc p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .tr-register {
    display: inline-block;
    background: var(--orange);
    color: #0f1014;
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    padding: 0.85rem 2rem;
    transition: background 0.2s;
    border: none;
    cursor: pointer;
    border-radius: 0;
    -webkit-appearance: none;
    appearance: none;
  }

  .tr-register:hover { background: #b8f020; }

  /* Access section */
  .tr-access {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .tr-access-heading {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 4.5vw, 4.5rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
    max-width: 800px;
    margin-bottom: 3rem;
  }

  .tr-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .tr-card {
    border: 1px solid var(--border);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tr-card-icon {
    color: var(--ink);
    opacity: 0.7;
    display: block;
    margin-bottom: 0.25rem;
  }

  .tr-card-title {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: var(--ink);
    text-transform: uppercase;
    line-height: 1.3;
  }

  .tr-card-body {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--muted);
  }

  /* Summer Schedule */
  .tr-schedule {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .tr-schedule-heading {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 4.5vw, 4.5rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .tr-schedule-sub {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--ink);
    margin-bottom: 0.4rem;
  }

  .tr-schedule-day {
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }

  .tr-schedule-location {
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 3rem;
  }

  .tr-sessions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .tr-session {
    border: 1px solid var(--border);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .tr-session-label {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--ink);
    text-transform: uppercase;
  }

  .tr-session-dates {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .tr-session-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--muted);
    flex: 1;
  }

  .tr-session-times-label {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: var(--ink);
    text-transform: uppercase;
    margin-top: 0.5rem;
