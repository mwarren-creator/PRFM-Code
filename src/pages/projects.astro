---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Projects — PRFM Sports" description="Multi-Purpose Sports Dome. A brand new indoor training facility in the heart of Utah County.">
  <Nav />

  <main>

    <!-- Hero with background image -->
    <section class="pj-hero">
      <div class="pj-hero-bg" aria-hidden="true"></div>
      <div class="pj-container pj-hero-content">
        <p class="pj-tag">THE PROJECT</p>
        <h1 class="pj-hero-heading">MULTI-PURPOSE<br/>SPORTS DOME</h1>
        <p class="pj-hero-sub">A brand new indoor training facility in the heart of Utah County, similar to the current UVU DoTerra Dome.</p>
      </div>
    </section>

    <!-- Stats bar -->
    <section class="pj-stats">
      <div class="pj-container">
        <div class="pj-stats-grid">
          <div class="pj-stat">
            <span class="pj-stat-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </span>
            <p class="pj-stat-number">20,000+</p>
            <p class="pj-stat-label">Youth soccer players in Utah County</p>
          </div>
          <div class="pj-stat">
            <span class="pj-stat-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </span>
            <p class="pj-stat-number">YEAR-ROUND</p>
            <p class="pj-stat-label">Indoor training access</p>
          </div>
        </div>
      </div>
    </section>

    <!-- The Opportunity -->
    <section class="pj-opportunity">
      <div class="pj-container">
        <div class="pj-two-col">
          <div class="pj-col-text">
            <p class="pj-tag">THE OPPORTUNITY</p>
            <h2 class="pj-section-heading">JOIN US IN INVESTING IN UTAH'S YOUTH ATHLETES</h2>
            <p class="pj-body">Join PRFM Sports Group in building a new sports dome for all levels of youth athletes. A public-private partnership (P3) near Vineyard/Pleasant Grove.</p>
          </div>
          <div class="pj-col-img">
            <img
              src="https://prfmsports.com/assets/dome-revenue-1-MMIwg2K6.jpg"
              alt="Indoor turf facility"
              class="pj-img"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Why Invest -->
    <section class="pj-why">
      <div class="pj-container">
        <p class="pj-tag">WHY INVEST</p>
        <h2 class="pj-section-heading">BUILT FOR IMPACT</h2>
        <div class="pj-cards-3">
          <div class="pj-card">
            <h3 class="pj-card-title">AMAZING FOR COMMUNITY</h3>
            <p class="pj-card-body">Utah needs more indoor training facilities that can provide thousands of youth a chance to keep playing the sports they love.</p>
          </div>
          <div class="pj-card">
            <h3 class="pj-card-title">HUGE ECONOMIC IMPACT</h3>
            <p class="pj-card-body">The sports dome will generate a flood of new revenue for Vineyard and Utah City.</p>
          </div>
          <div class="pj-card">
            <h3 class="pj-card-title">GROWING UTAH</h3>
            <p class="pj-card-body">Opportunity to provide more events and tournaments to grow Utah sports across the region.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Ideal Location -->
    <section class="pj-location">
      <div class="pj-container">
        <div class="pj-two-col pj-two-col--flip">
          <div class="pj-col-img">
            <img
              src="https://prfmsports.com/assets/dome-location-map-BCU_qcxk.png"
              alt="Dome location map in Vineyard, Utah"
              class="pj-img"
            />
          </div>
          <div class="pj-col-text">
            <p class="pj-tag">IDEAL LOCATION</p>
            <h2 class="pj-section-heading">HEART OF UTAH COUNTY</h2>
            <p class="pj-body">The Dome will be located in the heart of Utah County next to the fastest growing cities in Utah with a full state of the art turf field, offices and conference rooms.</p>
            <a
              href="https://maps.google.com/?q=400+North+and+Mill+Rd,+Vineyard,+UT+84059"
              class="pj-address"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              400 North and Mill Rd, Vineyard, UT 84059
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Programs -->
    <section class="pj-programs">
      <div class="pj-container">
        <div class="pj-two-col">
          <div class="pj-col-text">
            <p class="pj-tag">PARTICIPATION</p>
            <h2 class="pj-section-heading">PROGRAMS</h2>
          </div>
          <div class="pj-col-img">
            <img
              src="https://prfmsports.com/assets/dome-partnership-7ivAcFVr.png"
              alt="Indoor training zone"
              class="pj-img"
            />
          </div>
        </div>
        <div class="pj-cards-3" style="margin-top: 2rem;">
          <div class="pj-card">
            <h3 class="pj-card-title">PROGRAMS & ACADEMIES</h3>
            <p class="pj-card-body">Over 20,000 kids play soccer in Utah County looking to learn and improve their skills.</p>
          </div>
          <div class="pj-card">
            <h3 class="pj-card-title">RENTALS</h3>
            <p class="pj-card-body">Full size turf indoor, sub divided into halves and quarters during the winter to provide as many youth athletes a chance to train all winter long.</p>
          </div>
          <div class="pj-card">
            <h3 class="pj-card-title">COLLEGE ID EVENTS</h3>
            <p class="pj-card-body">Building with a college partner presents the opportunity to bring college coaches to Utah. 4+ events per year across multiple sports.</p>
          </div>
          <div class="pj-card">
            <h3 class="pj-card-title">COLLEGE ID EVENTS</h3>
            <p class="pj-card-body">Building with a college partner presents the opportunity to bring college coaches to Utah. 4+ events per year across multiple sports.</p>
          </div>
          <div class="pj-card">
            <h3 class="pj-card-title">TOURNAMENTS</h3>
            <p class="pj-card-body">Winter tournaments, showcases and more across multiple sports. Anticipated 100+ teams.</p>
          </div>
          <div class="pj-card">
            <h3 class="pj-card-title">LEAGUES</h3>
            <p class="pj-card-body">4 adult 8-week leagues and 2 youth leagues per year with consistent recurring revenue.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Traction & Milestones -->
    <section class="pj-traction">
      <div class="pj-container">
        <p class="pj-tag">TRACTION & MILESTONES</p>
        <h2 class="pj-traction-heading">LAUNCH DATE WINTER OF 2027</h2>
      </div>
    </section>

    <!-- Interested CTA -->
    <section class="pj-cta">
      <div class="pj-container">
        <div class="pj-cta-box">
          <div>
            <h2 class="pj-cta-heading">INTERESTED IN THE PROJECT?</h2>
            <p class="pj-cta-sub">Learn more about this investment opportunity and how you can be part of Utah's premier sports dome.</p>
          </div>
          <a href="mailto:info@prfmsports.com" class="pj-cta-btn">CONTACT US</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Base>

<style>
  .pj-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .pj-tag {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: var(--orange);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  /* Hero */
  .pj-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 3rem;
    overflow: hidden;
  }

  .pj-hero-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://prfmsports.com/assets/dome-opportunity-BACB85fh.jpg');
    background-size: cover;
    background-position: center;
    filter: brightness(0.45);
    z-index: 0;
  }

  .pj-hero-content {
    position: relative;
    z-index: 1;
  }

  .pj-hero-content .pj-tag {
    color: var(--orange);
  }

  .pj-hero-heading {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 8vw, 8rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
    color: #fff;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .pj-hero-sub {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.75);
    max-width: 560px;
  }

  /* Stats */
  .pj-stats {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border);
  }

  .pj-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .pj-stat {
    border: 1px solid var(--border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pj-stat-icon {
    color: var(--orange);
    opacity: 0.7;
    display: block;
    margin-bottom: 0.5rem;
  }

  .pj-stat-number {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .pj-stat-label {
    font-size: 0.9rem;
    color: var(--muted);
  }

  /* Two-col layout */
  .pj-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .pj-two-col--flip .pj-col-img { order: -1; }

  .pj-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  /* Section headings */
  .pj-section-heading {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 4.5vw, 4.5rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .pj-body {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted);
    margin-bottom: 1.25rem;
  }

  .pj-address {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--orange);
    text-transform: uppercase;
    transition: opacity 0.2s;
  }

  .pj-address:hover { opacity: 0.75; }

  /* Sections */
  .pj-opportunity {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .pj-why {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .pj-location {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .pj-programs {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  /* 3-col cards */
  .pj-cards-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .pj-card {
    border: 1px solid var(--border);
    padding: 1.75rem 1.5rem;
  }

  .pj-card-title {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .pj-card-body {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--muted);
  }

  /* Traction */
  .pj-traction {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .pj-traction-heading {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 4.5vw, 4.5rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
  }

  /* CTA box */
  .pj-cta {
    padding: 4rem 0 6rem;
  }

  .pj-cta-box {
    border: 1px solid var(--border);
    background: #fdf5f2;
    padding: 2.5rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .pj-cta-heading {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(1.25rem, 2.5vw, 2rem);
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .pj-cta-sub {
    font-size: 0.9rem;
    color: var(--muted);
    max-width: 520px;
  }

  .pj-cta-btn {
    display: inline-block;
    background: var(--orange);
    color: #fff;
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    padding: 0.9rem 2.5rem;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s;
  }

  .pj-cta-btn:hover { background: #d44420; }

  /* Responsive */
  @media (max-width: 900px) {
    .pj-two-col,
    .pj-two-col--flip {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .pj-two-col--flip .pj-col-img { order: 0; }
    .pj-stats-grid { grid-template-columns: 1fr; }
    .pj-cards-3 { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 480px) {
    .pj-cards-3 { grid-template-columns: 1fr; }
  }
</style>
