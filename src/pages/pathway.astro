---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Pathway — PRFM Sports" description="Utah Soccer Pathway Program. A clear plan, measurable progress, and a direct route to collegiate soccer — built for Utah players and the families behind them.">
  <Nav />

  <div class="topbar">
    <a href="/" class="topbar-back">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      BACK TO HOME
    </a>
  </div>

  <main>

    <!-- Hero -->
    <section class="pw-hero">
      <div class="pw-container">
        <h1 class="pw-heading">UTAH SOCCER<br/>PATHWAY PROGRAM</h1>
        <p class="pw-sub">A clear plan, measurable progress, and a direct route to collegiate soccer — built for Utah players and the families behind them.</p>
        <a href="#" class="pw-download">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          DOWNLOAD FREE PARENT GUIDE
        </a>
      </div>
    </section>

    <!-- Pricing cards -->
    <section class="pw-pricing">
      <div class="pw-container">
        <div class="pw-pricing-grid">

          <!-- Pathway Plus -->
          <div class="pw-card">
            <h2 class="pw-card-title">PATHWAY PLUS</h2>
            <div class="pw-price-row">
              <span class="pw-price-old">$399</span>
              <span class="pw-price-new">$299</span>
              <span class="pw-price-period">PER YEAR</span>
            </div>
            <span class="pw-discount-badge">OFF-SEASON DISCOUNT</span>
            <p class="pw-card-desc">For players and families who want a clear plan, measurable progress, and guidance through the recruiting process.</p>
            <a href="#" class="pw-card-btn">GET STARTED</a>

            <hr class="pw-divider" />

            <p class="pw-card-body">Utah Soccer Pathway Plus is designed for players and families who want expert guidance, a clear development plan, and a better understanding of the college soccer pathway.</p>
            <p class="pw-card-body">Whether your goal is to make the varsity team, compete at a higher club level, or pursue college soccer opportunities, Pathway Plus provides the tools, resources, and education needed to make informed decisions throughout the journey.</p>
            <p class="pw-card-body">Every Pathway Plus member begins with a personalized one-on-one consultation with a Utah Soccer Pathway Director. During this session, we will learn about the player's goals, current level, strengths, areas for improvement, and long-term aspirations. From there, we help create a customized roadmap designed to maximize development and future opportunities.</p>

            <p class="pw-includes-label">PATHWAY PLUS INCLUDES:</p>
            <ul class="pw-list">
              <li>Initial one-on-one consultation with a Utah Soccer Pathway Director</li>
              <li>Personalized Player Pathway Profile</li>
              <li>Annual Player Assessment and Development Review</li>
              <li>Recruiting Roadmap based on age and goals</li>
              <li>Verified Combine Metrics and Benchmark Comparisons</li>
              <li>Access to Parent Education Webinars</li>
              <li>Utah College Soccer Recruiting Guide</li>
              <li>Event Discounts for PRFM Combines and Workshops</li>
              <li>Monthly Pathway Newsletter and Recruiting Updates</li>
            </ul>
            <p class="pw-card-body">Pathway Plus gives families clarity, direction, and confidence while helping players stay focused on the steps that matter most in their development and recruiting journey.</p>

            <div class="pw-feature-list">
              <div class="pw-feature">
                <p class="pw-feature-label">UTAH SOCCER RECRUITING ROADMAP</p>
                <p class="pw-feature-sub">A customized roadmap based on the athlete's age and goals.</p>
                <ul class="pw-list pw-list--compact">
                  <li>Freshman year recommendations</li>
                  <li>Sophomore year action plan</li>
                  <li>Junior year recruiting timeline</li>
                  <li>Senior year recruiting checklist</li>
                  <li>Showcase recommendations</li>
                  <li>Video and communication guidance</li>
                </ul>
              </div>
              <div class="pw-feature">
                <p class="pw-feature-label">PARENT EDUCATION WEBINARS</p>
                <p class="pw-feature-sub">Live and recorded educational sessions throughout the year.</p>
                <ul class="pw-list pw-list--compact">
                  <li>College recruiting process</li>
                  <li>NCAA, NAIA, and JUCO pathways</li>
                  <li>Communicating with college coaches</li>
                  <li>Highlight video creation</li>
                  <li>Selecting the right club environment</li>
                  <li>Navigating showcases</li>
                </ul>
              </div>
              <div class="pw-feature">
                <p class="pw-feature-label">MONTHLY PATHWAY NEWSLETTER</p>
                <ul class="pw-list pw-list--compact">
                  <li>Recruiting tips</li>
                  <li>College commitments</li>
                  <li>Player spotlights</li>
                  <li>Utah soccer news</li>
                  <li>Recruiting deadlines and opportunities</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Pathway Elite -->
          <div class="pw-card pw-card--elite">
            <p class="pw-elite-sub">A PERSONALIZED PATHWAY FOR YOUR PLAYER</p>
            <h2 class="pw-card-title">PATHWAY ELITE</h2>
            <div class="pw-price-row">
              <span class="pw-price-old">$1,299</span>
              <span class="pw-price-new">$999</span>
              <span class="pw-price-period">PER YEAR</span>
            </div>
            <span class="pw-discount-badge">OFF-SEASON DISCOUNT</span>
            <p class="pw-card-desc">For serious players pursuing collegiate soccer and families who want personalized guidance, accountability, and strategy through the recruiting journey.</p>
            <a href="#" class="pw-card-btn">GET STARTED</a>

            <p class="pw-elite-intro">Everything included in Utah Soccer Pathway Plus, along with personalized recruiting support designed to help players and families navigate the college recruiting process with confidence.</p>

            <div class="pw-feature-list">
              <div class="pw-feature">
                <p class="pw-feature-label">PERSONALIZED RECRUITING STRATEGY</p>
                <p class="pw-feature-body">Every athlete's journey is different. Through one-on-one strategy sessions with the player and family, we help create a realistic and actionable recruiting plan based on the athlete's goals, abilities, academic profile, and desired college experience. Together, we'll identify the right opportunities, establish priorities, and build a roadmap that keeps the recruiting process organized and focused.</p>
              </div>
              <div class="pw-feature">
                <p class="pw-feature-label">COLLEGE FIT & MATCHING ANALYSIS</p>
                <p class="pw-feature-body">Finding the right school is about much more than soccer. We help families identify programs that align with the player's athletic ability, academic goals, geographic preferences, financial considerations, and overall college experience. Athletes receive a customized list of target schools and programs that fit their profile and long-term objectives.</p>
              </div>
              <div class="pw-feature">
                <p class="pw-feature-label">PERSONALIZED RECRUITING ROADMAP</p>
                <p class="pw-feature-body">Recruiting can feel overwhelming without a clear plan. Our team develops a year-round roadmap that outlines key milestones, recommended showcases, communication timelines, video development priorities, and recruiting objectives. Players always know what steps to take next and when to take them.</p>
              </div>
              <div class="pw-feature">
                <p class="pw-feature-label">HIGHLIGHT VIDEO REVIEW & FEEDBACK</p>
                <p class="pw-feature-body">A player's video is often the first impression they make on a college coach. We provide professional feedback on highlight videos, helping athletes select the right clips, organize content effectively, and showcase their strengths. Players receive position-specific recommendations and insights from a college coach's perspective to maximize exposure and impact.</p>
              </div>
              <div class="pw-feature">
                <p class="pw-feature-label">COLLEGE COACH COMMUNICATION SUPPORT</p>
                <p class="pw-feature-body">Many athletes miss opportunities simply because they don't know how to communicate with coaches effectively. We provide proven outreach templates, communication strategies, and guidance on when and how to connect with college programs.</p>
                <ul class="pw-list pw-list--compact">
                  <li>Introduction email templates</li>
                  <li>Follow-up communication strategies</li>
                  <li>Showcase notification emails</li>
                  <li>Thank-you and relationship-building templates</li>
                  <li>Recruiting outreach best practices</li>
                </ul>
              </div>
              <div class="pw-feature">
                <p class="pw-feature-label">RECRUITING READINESS EVALUATION</p>
                <p class="pw-feature-body">Families deserve honest feedback. Our Recruiting Readiness Evaluation provides a realistic assessment of where the athlete currently fits within the college soccer landscape and what improvements may be necessary to reach the next level.</p>
                <ul class="pw-list pw-list--compact">
                  <li>NCAA Division I</li>
                  <li>NCAA Division II</li>
                  <li>NCAA Division III</li>
                  <li>NAIA</li>
                  <li>Junior College</li>
                </ul>
              </div>
              <div class="pw-feature">
                <p class="pw-feature-label">QUARTERLY RECRUITING CHECK-INS</p>
                <p class="pw-feature-body">Throughout the year, athletes and families meet with our team to review progress and make adjustments as needed. These sessions help ensure players remain on track and continue taking the right actions at the right time.</p>
                <ul class="pw-list pw-list--compact">
                  <li>Recruiting activity updates</li>
                  <li>School engagement progress</li>
                  <li>Development priorities</li>
                  <li>Goal adjustments</li>
                  <li>Action items for the upcoming quarter</li>
                </ul>
              </div>
              <div class="pw-feature">
                <p class="pw-feature-label">PRIORITY ACCESS TO PRFM EVENTS</p>
                <p class="pw-feature-body">Elite Recruiting members receive priority registration opportunities and preferred pricing for select PRFM Sports events, including combines, recruiting showcases, educational workshops, and future player development opportunities.</p>
              </div>
              <div class="pw-feature">
                <p class="pw-feature-label">COLLEGE RECRUITING RESOURCE LIBRARY</p>
                <p class="pw-feature-body">Members gain access to an expanding collection of recruiting resources designed to simplify the process and provide clarity for both players and parents.</p>
                <ul class="pw-list pw-list--compact">
                  <li>Recruiting timelines</li>
                  <li>Recruiting checklists</li>
                  <li>College planning resources</li>
                  <li>Academic preparation tools</li>
                  <li>Scholarship information</li>
                  <li>Recruiting education materials</li>
                </ul>
              </div>
              <div class="pw-feature">
                <p class="pw-feature-label">YOUR RECRUITING PARTNER</p>
                <p class="pw-feature-body">The goal of Utah Soccer Pathway Elite Recruiting is simple: provide athletes and families with expert guidance, accountability, and a clear plan so they can make informed decisions and maximize their opportunities to play soccer at the collegiate level.</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Contact CTA -->
    <section class="pw-contact">
      <div class="pw-container">
        <div class="pw-contact-inner">
          <div>
            <h2 class="pw-contact-heading">QUESTIONS ABOUT THE<br/>PATHWAY?</h2>
            <p class="pw-contact-sub">Reach out and we'll help you choose the right tier for your athlete.</p>
          </div>
          <a href="mailto:info@prfmsports.com" class="pw-contact-btn">CONTACT US</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Base>

<style>
  .topbar {
    position: sticky;
    top: 60px;
    z-index: 90;
    background: var(--cream);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    height: 52px;
    display: flex;
    align-items: center;
  }

  .topbar-back {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.2s;
  }

  .topbar-back:hover { color: var(--orange); }

  .pw-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .pw-hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .pw-heading {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 6vw, 6.5rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .pw-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--muted);
    max-width: 560px;
    margin-bottom: 2.5rem;
  }

  .pw-download {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--orange);
    color: #fff;
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    padding: 0.85rem 1.75rem;
    transition: background 0.2s;
  }

  .pw-download:hover { background: #d44420; }

  /* Pricing */
  .pw-pricing {
    padding: 5rem 0 6rem;
  }

  .pw-pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .pw-card {
    border: 1px solid var(--border);
    padding: 2.5rem 2rem;
    background: var(--cream);
  }

  .pw-card--elite {
    border-color: var(--orange);
  }

  .pw-elite-sub {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .pw-card-title {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .pw-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .pw-price-old {
    font-family: 'Archivo Black', sans-serif;
    font-size: 1.25rem;
    color: var(--muted);
    text-decoration: line-through;
    opacity: 0.6;
  }

  .pw-price-new {
    font-family: 'Archivo Black', sans-serif;
    font-size: 2.5rem;
    color: var(--orange);
    line-height: 1;
  }

  .pw-price-period {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .pw-discount-badge {
    display: inline-block;
    background: var(--orange);
    color: #fff;
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.6rem;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .pw-card-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  .pw-card-btn {
    display: inline-block;
    background: var(--orange);
    color: #fff;
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    padding: 0.8rem 2rem;
    transition: background 0.2s;
    margin-bottom: 2rem;
  }

  .pw-card-btn:hover { background: #d44420; }

  .pw-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin-bottom: 2rem;
  }

  .pw-card-body {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .pw-includes-label {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    color: var(--ink);
    text-transform: uppercase;
    margin: 1.5rem 0 0.75rem;
  }

  .pw-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .pw-list li {
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--muted);
    padding-left: 1rem;
    position: relative;
  }

  .pw-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    background: var(--orange);
  }

  .pw-list--compact {
    gap: 0.35rem;
    margin-top: 0.5rem;
  }

  .pw-feature-list {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    margin-top: 2rem;
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }

  .pw-feature-label {
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .pw-feature-sub {
    font-size: 0.88rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
    font-style: italic;
  }

  .pw-feature-body {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .pw-elite-intro {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--orange);
    font-style: italic;
    margin-bottom: 1.5rem;
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }

  /* Contact CTA */
  .pw-contact {
    border-top: 1px solid var(--border);
    padding: 4rem 0 5rem;
  }

  .pw-contact-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .pw-contact-heading {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(1.75rem, 3.5vw, 3.5rem);
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .pw-contact-sub {
    font-size: 0.95rem;
    color: var(--muted);
  }

  .pw-contact-btn {
    display: inline-block;
    background: var(--orange);
    color: #fff;
    font-family: 'Archivo Black', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    padding: 0.9rem 2.5rem;
    white-space: nowrap;
    transition: background 0.2s;
    flex-shrink: 0;
  }

  .pw-contact-btn:hover { background: #d44420; }

  @media (max-width: 900px) {
    .pw-pricing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
