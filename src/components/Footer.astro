---
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <p class="footer-logo">PRFM<br /><span>SPORTS</span></p>
      <p class="footer-tagline">
        PRFM Sports is a modern sports management group focused on building high-impact events and operating best-in-class facilities.
      </p>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">SERVICES</h3>
      <ul class="footer-list">
        <li><a href="/events">Events</a></li>
        <li><a href="/services#trainings">Trainings</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">COMPANY</h3>
      <ul class="footer-list">
        <li><a href="/about">About</a></li>
        <li><a href="/careers">Careers</a></li>
        <li><a href="/partners">Partners</a></li>
        <li><a href="#">Press</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">CONTACT</h3>
      <ul class="footer-list">
        <li><a href="mailto:info@prfmsports.com">info@prfmsports.com</a></li>
        <li class="footer-social">
          <a href="https://www.instagram.com/prfmsports/" aria-label="PRFM Sports on Instagram" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/prfmsports" aria-label="PRFM Sports on LinkedIn" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </li>
        <li class="footer-copy">© 2026 PRFM Sports. All rights reserved.</li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: rgba(255,255,255,0.6);
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .footer-inner {
    
    margin: 0 auto;
    padding: 4rem 5rem;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 3rem;
  }

  .footer-logo {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: 1.8rem;
    color: white;
    line-height: 1;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }

  .footer-logo span {
    font-weight: 400;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
  }

  .footer-tagline {
    font-size: 0.88rem;
    line-height: 1.6;
    max-width: 280px;
  }

  .footer-heading {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    color: white;
    margin-bottom: 1rem;
  }

  .footer-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-list a {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.55);
    transition: color 0.2s;
  }

  .footer-list a:hover {
    color: rgba(255,255,255,0.9);
  }

  .footer-social {
    display: flex;
    gap: 1rem;
    margin-top: 0.25rem;
  }

  .footer-social a {
    color: rgba(255,255,255,0.55);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .footer-social a:hover {
    color: white;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
    margin-top: 0.5rem;
  }

  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
