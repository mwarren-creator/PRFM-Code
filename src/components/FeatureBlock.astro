---
interface Props {
  number: string;
  title: string;
  description: string;
  bullets: string[];
  ctaLabel: string;
  ctaHref: string;
  flip?: boolean;
  dark?: boolean;
}

const { number, title, description, bullets, ctaLabel, ctaHref, flip = false, dark = false } = Astro.props;
---

<section class:list={['feature', { 'feature--dark': dark }]}>
  <div class:list={['feature-inner', { 'feature-inner--flip': flip }]}>
    <div class="feature-left">
      <span class="feature-num">{number}</span>
      <h2 class="feature-title">{title}</h2>
    </div>

    <div class="feature-right">
      <p class="feature-desc">{description}</p>
      <ul class="feature-bullets">
        {bullets.map(b => (
          <li class="feature-bullet">
            <span class="bullet-dot" aria-hidden="true">&#9642;</span>
            {b}
          </li>
        ))}
      </ul>
      <a href={ctaHref} class="feature-cta">
        {ctaLabel} <span class="feature-arrow" aria-hidden="true">&nbsp;&rarr;</span>
      </a>
    </div>
  </div>
</section>

<style>
  .feature {
    background: var(--cream);
    border-bottom: 1px solid var(--border);
  }

  .feature--dark {
    background: var(--cream);
  }

  .feature-inner {
    
    margin: 0 auto;
    padding: 6rem 5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .feature-inner--flip {
    direction: rtl;
  }

  .feature-inner--flip > * {
    direction: ltr;
  }

  .feature-left {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .feature-num {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--ink);
  }

  .feature-title {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 0.92;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-transform: uppercase;
  }

  .feature-right {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding-top: 1.25rem;
  }

  .feature-desc {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--muted);
  }

  .feature-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feature-bullet {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--ink);
  }

  .bullet-dot {
    color: var(--ink);
    font-size: 0.55rem;
    margin-top: 0.45rem;
    flex-shrink: 0;
  }

  .feature-cta {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 800;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: #0f1014;
    background: var(--orange);
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    text-transform: uppercase;
    padding: 0.75rem 1.75rem;
    transition: background 0.2s;
    gap: 0.4rem;
  }

  .feature-cta:hover {
    background: #b8f020;
  }

  @media (max-width: 768px) {
    .feature-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 3.5rem 1.5rem;
    }

    .feature-inner--flip {
      direction: ltr;
    }
  }
</style>
