---
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-blob hero-blob--1"></div>
    <div class="hero-blob hero-blob--2"></div>
    <div class="hero-blob hero-blob--3"></div>
    <div class="hero-blob hero-blob--4"></div>
  </div>

  <div class="hero-inner">
    <div class="hero-wordmark" aria-label="PRFM Sports">
      <span class="hero-prfm">PRFM</span>
      <span class="hero-sports">SPORTS<span class="hero-dot" aria-hidden="true"></span></span>
    </div>

    <div class="hero-info">
      <p class="hero-desc">
        PRFM Sports is a modern sports management group focused on building high-impact events, developing the next generation of athletes, and operating best-in-class facilities.
      </p>
      <div class="hero-actions">
        <a href="/training" class="btn btn--filled">GET STARTED</a>
        <a href="/pathway" class="btn btn--outline">EXPLORE</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 75vh;
    padding-top: 60px;
    overflow: clip;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: #ffffff;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    background: #cfff3d;
  }

  .hero-blob--1 {
    top: -30%;
    left: -15%;
    width: 80vw;
    height: 80vw;
    opacity: 0.6;
    filter: blur(65px);
  }

  .hero-blob--2 {
    bottom: -40%;
    left: 0%;
    width: 60vw;
    height: 60vw;
    opacity: 0.38;
    filter: blur(80px);
  }

  .hero-blob--3 {
    top: 10%;
    left: 30%;
    width: 45vw;
    height: 45vw;
    opacity: 0.25;
    filter: blur(90px);
  }

  .hero-blob--4 {
    top: -10%;
    right: 5%;
    width: 35vw;
    height: 35vw;
    opacity: 0.12;
    filter: blur(100px);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    height: calc(75vh - 60px);
    
    margin: 0 auto;
    padding: 3.5rem 5rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hero-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 0.88;
  }

  .hero-prfm {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(5rem, 9.6vw, 9.6vw);
    color: #141414;
    letter-spacing: 0.35em;
    display: block;
  }

  .hero-sports {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: clamp(4.5rem, 9.1vw, 9.1vw);
    color: #141414;
    letter-spacing: 0.35em;
    display: inline-flex;
    align-items: flex-end;
    gap: 0.25em;
  }

  .hero-dot {
    display: inline-block;
    width: 0.2em;
    height: 0.2em;
    background: var(--orange);
    flex-shrink: 0;
    margin-bottom: 0.1em;
  }

  .hero-tagline {
    font-family: 'Archivo Black', sans-serif;
    font-size: clamp(0.75rem, 1.2vw, 1.2vw);
    letter-spacing: 0.15em;
    color: rgba(15, 16, 20, 0.55);
    text-transform: uppercase;
    margin-top: 0.75rem;
    display: block;
  }

  .hero-info {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    align-self: flex-end;
    max-width: 480px;
  }

  .hero-desc {
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(30, 18, 14, 0.7);
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    font-family: 'Archivo Black', sans-serif;
    font-weight: 900;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    padding: 0.75rem 1.75rem;
    display: inline-block;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .btn--filled {
    background: #cfff3d;
    color: #0f1014;
  }

  .btn--filled:hover {
    background: #b8f020;
  }

  .btn--outline {
    background: var(--orange);
    color: #0f1014;
    border: none;
  }

  .btn--outline:hover {
    background: #b8f020;
  }

  @media (max-width: 768px) {
    .hero-info {
      align-self: flex-start;
    }
  }
</style>
